# ── Instagram Graph API ────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values, then restart `npm run dev`.
# Without these, the site shows curated sample images automatically.

# Long-lived access token from the Meta / Instagram Graph API
VITE_IG_ACCESS_TOKEN=

# Your Instagram Business/Creator account's user id (a long number)
VITE_IG_USER_ID=

# OPTIONAL — recommended for production.
# If you deploy a small serverless proxy that keeps the token server-side,
# set its URL here and it will be used instead of calling Graph API directly.
# VITE_IG_PROXY_URL=https://your-site.com/api/instagram
